@{
    Layout = "_LayoutAdmin";
}

@model IEnumerable<CMS.Data.Entities.CategoryProduct>

@{
    ViewData["Title"] = "Danh sách Category Product";
}

<div class="container mt-4">
    <div class="card shadow">

        <!-- HEADER -->
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">📦 Danh sách Category Product</h4>
            <a asp-action="Create" class="btn btn-light btn-sm">
                ➕ Thêm mới
            </a>
        </div>

        <!-- BODY -->
        <div class="card-body">
            <table class="table table-hover table-striped align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 10%">ID</th>
                        <th style="width: 40%">Tên</th>
                        <th style="width: 50%">Chức năng</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Id</strong></td>
                                <td>@item.Name</td>

                                <td>
                                    <div class="d-flex justify-content-center gap-2">

                                        <!-- DETAILS -->
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-info btn-sm">
                                            👁 Chi tiết
                                        </a>

                                        <!-- EDIT -->
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-warning btn-sm">
                                            ✏️ Sửa
                                        </a>

                                        <!-- DELETE (POST FORM) -->
                                        <form asp-action="Delete"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              onsubmit="return confirm('Bạn có chắc muốn xoá không?');">

                                            @Html.AntiForgeryToken()

                                            <button type="submit" class="btn btn-danger btn-sm">
                                                🗑 Xoá
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted">
                                ⚠️ Chưa có dữ liệu
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>
</div>