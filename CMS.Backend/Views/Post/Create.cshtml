@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm bài viết mới";
}

<div class="container mt-4">
    <div class="card shadow">

        <!-- HEADER -->
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                <i class="bi bi-file-earmark-plus"></i> THÊM BÀI VIẾT MỚI
            </h4>
        </div>

        <!-- BODY -->
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="row">

                    <!-- LEFT -->
                    <div class="col-md-8">

                        <!-- TITLE -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề bài viết:</label>
                            <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." />
                        </div>

                        <!-- CONTENT (CKEDITOR) -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nội dung chi tiết:</label>
                            <textarea asp-for="Content" id="Content" class="form-control" rows="10"></textarea>
                        </div>

                    </div>

                    <!-- RIGHT -->
                    <div class="col-md-4">

                        <!-- CATEGORY -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chuyên mục:</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.CategoryList" class="form-select">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>

                        <!-- IMAGE URL -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Link ảnh (URL):</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                        </div>

                        <!-- UPLOAD IMAGE -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Upload ảnh:</label>
                            <input type="file" name="uploadImage" class="form-control" />
                        </div>

                        <hr />

                        <!-- BUTTON -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-cloud-arrow-up"></i> Lưu và Đăng bài
                            </button>

                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                        </div>

                    </div>

                </div>
            </form>
        </div>
    </div>
</div>

<!-- CKEDITOR -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

    <script>
        ClassicEditor
            .create(document.querySelector('#Content'))
            .catch(error => {
                console.error(error);
            });
    </script>
}