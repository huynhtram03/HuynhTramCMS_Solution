@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="container mt-5">

    <!-- BREADCRUMB -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-light p-2 rounded shadow-sm">
            <li class="breadcrumb-item">
                <a asp-controller="Post" asp-action="Index">Danh sách bài viết</a>
            </li>
            <li class="breadcrumb-item active">
                Chi tiết bài viết
            </li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- TITLE -->
            <h1 class="fw-bold text-primary mb-3">
                @Model.Title
            </h1>

            <!-- META -->
            <div class="d-flex flex-wrap gap-3 text-muted mb-3">

                <div>
                    <i class="bi bi-calendar"></i>
                    @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                </div>

                <div>
                    <i class="bi bi-folder"></i>
                    <span class="badge bg-primary">
                        @(Model.Category != null ? Model.Category.Name : "Không có")
                    </span>
                </div>

            </div>

            <hr />

            <!-- IMAGE -->
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="text-center mb-4">
                    <img src="@Model.ImageUrl"
                         class="img-fluid rounded shadow"
                         style="max-height:400px; object-fit:cover; width:100%;">
                </div>
            }

            <!-- CONTENT -->
            <div class="post-content fs-5 lh-lg">
                @Html.Raw(Model.Content)
            </div>

            <!-- BUTTON -->
            <div class="mt-5 d-flex gap-2 border-top pt-3">

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>

                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Sửa
                </a>

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Bạn có chắc muốn xoá bài viết này?');">
                    @Html.AntiForgeryToken()

                    <button class="btn btn-danger">
                        <i class="bi bi-trash"></i> Xoá
                    </button>
                </form>

            </div>

        </div>
    </div>
</div>