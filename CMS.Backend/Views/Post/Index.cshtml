@model IEnumerable<CMS.Data.Entities.Post>

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark fw-bold">
            <i class="bi bi-file-earmark-text"></i> DANH SÁCH BÀI VIẾT
        </h2>

        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm bài viết mới
        </a>
    </div>

    <!-- LIST -->
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">

                    <!-- IMAGE -->
                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;"
                         alt="Thumbnail">

                    <div class="card-body d-flex flex-column">

                        <!-- CATEGORY -->
                        <span class="badge bg-info text-dark mb-2">
                            @item.Category?.Name
                        </span>

                        <!-- TITLE -->
                        <h5 class="card-title text-primary fw-bold">
                            @item.Title
                        </h5>

                        <!-- CONTENT -->
                        <p class="card-text text-muted"
                           style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">
                            @item.Content
                        </p>

                        <!-- DATE -->
                        <p class="text-muted small mt-auto">
                            <i class="bi bi-calendar"></i>
                            @item.CreatedDate.ToString("dd/MM/yyyy")
                        </p>

                        <!-- ACTION -->
                        <div class="d-flex justify-content-between">

                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye"></i> Xem
                            </a>

                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-pencil"></i> Sửa
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-outline-danger btn-sm"
                               onclick="return confirm('Bạn chắc chắn muốn xoá bài viết này?')">
                                <i class="bi bi-trash"></i> Xóa
                            </a>

                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

</div>