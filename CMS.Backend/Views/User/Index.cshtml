@{
    Layout = "_LayoutAdmin";
}
@model IEnumerable<CMS.Data.Entities.User>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark fw-bold">👤 QUẢN LÝ THÀNH VIÊN</h2>

        <a asp-controller="User" asp-action="Create"
           class="btn btn-success btn-sm">
            ➕ Thêm thành viên mới
        </a>
    </div>

    <!-- TABLE -->
    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 5%">ID</th>
                        <th style="width: 20%">Tên Đăng Nhập</th>
                        <th style="width: 25%">Họ Và Tên</th>
                        <th style="width: 20%">Quyền Hạn</th>
                        <th style="width: 30%">Thao Tác</th>
                    </tr>
                </thead>

                <tbody class="text-center align-middle">
                    @if (Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.Id</td>

                                <td>
                                    <strong class="text-primary">
                                        @user.Username
                                    </strong>
                                </td>

                                <td>@user.FullName</td>

                                <td>
                                    @if (user.Role == "Administrator")
                                    {
                                        <span class="badge bg-danger px-3 py-2">
                                            🔑 @user.Role
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark px-3 py-2">
                                            👤 @user.Role
                                        </span>
                                    }
                                </td>

                                <td class="d-flex justify-content-center gap-2">

                                    <!-- EDIT -->
                                    <a asp-action="Edit" asp-route-id="@user.Id"
                                       class="btn btn-outline-warning btn-sm">
                                        ✏️
                                    </a>

                                    <!-- DELETE (CHUẨN POST) -->
                                    <form asp-action="Delete" method="post"
                                          onsubmit="return confirm('Bạn có chắc muốn xoá @user.Username không?');">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm">
                                            🗑
                                        </button>
                                    </form>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-muted py-3">
                                ⚠️ Chưa có dữ liệu người dùng
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>
</div>